{
  "projectInfo": {
    "name": "Academia Java - Frontend MVP",
    "description": "MVP para gestão de academias com fluxo completo de Prospect → Aluno → Matrícula → Plano → Pagamento",
    "techStack": {
      "suggested": ["React", "TypeScript", "TailwindCSS", "React Query", "React Router"],
      "database": "LocalStorage ou IndexedDB para persistência mockada",
      "stateManagement": "Context API ou Zustand"
    },
    "mvpScope": "Frontend funcional com dados mockados, navegação completa, validações e fluxos de negócio"
  },

  "dataModel": {
    "prospect": {
      "description": "Pessoa interessada que ainda não é aluno. Pode vir de visita presencial, WhatsApp, Instagram, etc.",
      "fields": {
        "id": { "type": "UUID", "auto": true },
        "tenantId": { "type": "UUID", "required": true },
        "nome": { "type": "string", "required": true, "minLength": 3, "maxLength": 100 },
        "email": { "type": "string", "required": false, "validation": "email" },
        "telefone": { "type": "string", "required": true, "description": "Principal forma de contato" },
        "cpf": { "type": "string", "required": false, "mask": "000.000.000-00" },
        "origem": { "type": "enum", "values": ["VISITA_PRESENCIAL", "WHATSAPP", "INSTAGRAM", "FACEBOOK", "INDICACAO", "SITE", "OUTROS"] },
        "observacoes": { "type": "string", "required": false },
        "status": { "type": "enum", "values": ["NOVO", "EM_CONTATO", "AGENDOU_VISITA", "VISITOU", "CONVERTIDO", "PERDIDO"], "default": "NOVO" },
        "dataCriacao": { "type": "datetime", "auto": true },
        "dataUltimoContato": { "type": "datetime", "required": false },
        "motivoPerda": { "type": "string", "required": false, "description": "Preenchido quando status = PERDIDO" }
      },
      "uniqueConstraint": "Para identificar unicidade: telefone OU (cpf se preenchido) OU email",
      "businessRules": [
        "Ao converter para aluno, criar registro em 'aluno' e mudar status para CONVERTIDO",
        "Telefone é obrigatório pois é o principal canal de contato",
        "CPF é opcional inicialmente, mas obrigatório para virar aluno"
      ]
    },

    "aluno": {
      "description": "Cliente efetivo da academia. Prospect convertido.",
      "fields": {
        "id": { "type": "UUID", "auto": true },
        "tenantId": { "type": "UUID", "required": true },
        "prospectId": { "type": "UUID", "required": false, "description": "Referência ao prospect original se houver" },
        "nome": { "type": "string", "required": true, "minLength": 3, "maxLength": 100 },
        "email": { "type": "string", "required": true, "validation": "email" },
        "telefone": { "type": "string", "required": true },
        "telefoneSec": { "type": "string", "required": false, "description": "Telefone secundário" },
        "cpf": { "type": "string", "required": true, "mask": "000.000.000-00", "unique": true },
        "rg": { "type": "string", "required": false },
        "dataNascimento": { "type": "date", "required": true },
        "sexo": { "type": "enum", "values": ["M", "F", "OUTRO"], "required": true },
        "endereco": {
          "type": "object",
          "fields": {
            "cep": { "type": "string", "mask": "00000-000" },
            "logradouro": { "type": "string" },
            "numero": { "type": "string" },
            "complemento": { "type": "string" },
            "bairro": { "type": "string" },
            "cidade": { "type": "string" },
            "estado": { "type": "string", "maxLength": 2 }
          }
        },
        "contatoEmergencia": {
          "type": "object",
          "fields": {
            "nome": { "type": "string", "required": true },
            "telefone": { "type": "string", "required": true },
            "parentesco": { "type": "string" }
          }
        },
        "observacoesMedicas": { "type": "string", "description": "Restrições, alergias, condições" },
        "foto": { "type": "string", "description": "URL ou base64 da foto" },
        "status": { "type": "enum", "values": ["ATIVO", "INATIVO", "BLOQUEADO", "CANCELADO"], "default": "ATIVO" },
        "dataCadastro": { "type": "datetime", "auto": true },
        "dataAtualizacao": { "type": "datetime", "auto": true }
      },
      "businessRules": [
        "CPF deve ser único por tenant",
        "Ao criar aluno, automaticamente criar conta financeira vinculada",
        "Status BLOQUEADO = inadimplente, pode treinar após regularizar",
        "Status CANCELADO = cancelou matrícula"
      ]
    },

    "plano": {
      "description": "Planos de assinatura disponíveis na academia",
      "fields": {
        "id": { "type": "UUID", "auto": true },
        "tenantId": { "type": "UUID", "required": true },
        "nome": { "type": "string", "required": true, "example": "Mensal Básico" },
        "descricao": { "type": "string" },
        "tipo": { "type": "enum", "values": ["MENSAL", "TRIMESTRAL", "SEMESTRAL", "ANUAL", "AVULSO"], "required": true },
        "duracaoDias": { "type": "integer", "required": true, "description": "30, 90, 180, 365, etc." },
        "valor": { "type": "decimal", "required": true, "precision": 2 },
        "valorMatricula": { "type": "decimal", "default": 0, "description": "Taxa de matrícula" },
        "atividades": { "type": "array<UUID>", "description": "IDs das atividades incluídas" },
        "beneficios": { "type": "array<string>", "description": "Lista de benefícios do plano" },
        "ativo": { "type": "boolean", "default": true },
        "destaque": { "type": "boolean", "default": false, "description": "Plano em destaque/recomendado" },
        "ordem": { "type": "integer", "description": "Ordem de exibição" },
        "dataCriacao": { "type": "datetime", "auto": true }
      },
      "examples": [
        { "nome": "Mensal Básico", "tipo": "MENSAL", "duracaoDias": 30, "valor": 99.90 },
        { "nome": "Trimestral", "tipo": "TRIMESTRAL", "duracaoDias": 90, "valor": 269.90 },
        { "nome": "Semestral", "tipo": "SEMESTRAL", "duracaoDias": 180, "valor": 499.90 },
        { "nome": "Anual VIP", "tipo": "ANUAL", "duracaoDias": 365, "valor": 899.90, "destaque": true }
      ]
    },

    "atividade": {
      "description": "Atividades/modalidades oferecidas pela academia",
      "fields": {
        "id": { "type": "UUID", "auto": true },
        "tenantId": { "type": "UUID", "required": true },
        "nome": { "type": "string", "required": true, "example": "Musculação" },
        "descricao": { "type": "string" },
        "categoria": { "type": "enum", "values": ["MUSCULACAO", "CARDIO", "COLETIVA", "LUTA", "AQUATICA", "OUTRA"] },
        "icone": { "type": "string", "description": "Nome do ícone ou emoji" },
        "cor": { "type": "string", "description": "Cor para identificação visual", "example": "#FF5733" },
        "ativo": { "type": "boolean", "default": true }
      },
      "examples": [
        { "nome": "Musculação", "categoria": "MUSCULACAO", "icone": "💪" },
        { "nome": "Spinning", "categoria": "CARDIO", "icone": "🚴" },
        { "nome": "Yoga", "categoria": "COLETIVA", "icone": "🧘" },
        { "nome": "Muay Thai", "categoria": "LUTA", "icone": "🥊" },
        { "nome": "Natação", "categoria": "AQUATICA", "icone": "🏊" },
        { "nome": "Funcional", "categoria": "COLETIVA", "icone": "🏋️" },
        { "nome": "Pilates", "categoria": "COLETIVA", "icone": "🤸" }
      ]
    },

    "matricula": {
      "description": "Vínculo entre aluno e plano. Representa a assinatura ativa.",
      "fields": {
        "id": { "type": "UUID", "auto": true },
        "tenantId": { "type": "UUID", "required": true },
        "alunoId": { "type": "UUID", "required": true },
        "planoId": { "type": "UUID", "required": true },
        "dataInicio": { "type": "date", "required": true },
        "dataFim": { "type": "date", "required": true, "calculated": "dataInicio + plano.duracaoDias" },
        "valorPago": { "type": "decimal", "required": true, "description": "Valor efetivamente pago (pode ter desconto)" },
        "valorMatricula": { "type": "decimal", "default": 0 },
        "desconto": { "type": "decimal", "default": 0 },
        "motivoDesconto": { "type": "string" },
        "formaPagamento": { "type": "enum", "values": ["DINHEIRO", "PIX", "CARTAO_CREDITO", "CARTAO_DEBITO", "BOLETO", "RECORRENTE"], "required": true },
        "status": { "type": "enum", "values": ["ATIVA", "VENCIDA", "CANCELADA", "SUSPENSA"], "default": "ATIVA" },
        "renovacaoAutomatica": { "type": "boolean", "default": false },
        "observacoes": { "type": "string" },
        "dataCriacao": { "type": "datetime", "auto": true },
        "dataAtualizacao": { "type": "datetime", "auto": true }
      },
      "businessRules": [
        "Ao criar matrícula, gerar pagamento correspondente",
        "dataFim é calculada automaticamente: dataInicio + plano.duracaoDias",
        "Se renovacaoAutomatica = true, gerar nova matrícula quando vencer",
        "Aluno só pode ter UMA matrícula ATIVA por vez",
        "Ao vencer, status muda para VENCIDA e aluno fica BLOQUEADO"
      ]
    },

    "pagamento": {
      "description": "Pagamentos de mensalidades e taxas",
      "fields": {
        "id": { "type": "UUID", "auto": true },
        "tenantId": { "type": "UUID", "required": true },
        "alunoId": { "type": "UUID", "required": true },
        "matriculaId": { "type": "UUID", "required": false },
        "tipo": { "type": "enum", "values": ["MATRICULA", "MENSALIDADE", "TAXA", "PRODUTO", "AVULSO"] },
        "descricao": { "type": "string", "required": true },
        "valor": { "type": "decimal", "required": true },
        "desconto": { "type": "decimal", "default": 0 },
        "valorFinal": { "type": "decimal", "calculated": "valor - desconto" },
        "dataVencimento": { "type": "date", "required": true },
        "dataPagamento": { "type": "date", "required": false },
        "formaPagamento": { "type": "enum", "values": ["DINHEIRO", "PIX", "CARTAO_CREDITO", "CARTAO_DEBITO", "BOLETO"] },
        "status": { "type": "enum", "values": ["PENDENTE", "PAGO", "VENCIDO", "CANCELADO"], "default": "PENDENTE" },
        "comprovante": { "type": "string", "description": "URL ou referência do comprovante" },
        "observacoes": { "type": "string" },
        "dataCriacao": { "type": "datetime", "auto": true }
      },
      "businessRules": [
        "Ao criar matrícula, criar pagamento automaticamente",
        "Pagamentos vencidos devem mudar status do aluno para BLOQUEADO",
        "Ao pagar, preencher dataPagamento e mudar status para PAGO"
      ]
    },

    "formaPagamento": {
      "description": "Formas de pagamento aceitas pela academia (configurável)",
      "fields": {
        "id": { "type": "UUID", "auto": true },
        "tenantId": { "type": "UUID", "required": true },
        "nome": { "type": "string", "required": true },
        "tipo": { "type": "enum", "values": ["DINHEIRO", "PIX", "CARTAO_CREDITO", "CARTAO_DEBITO", "BOLETO", "RECORRENTE"] },
        "ativo": { "type": "boolean", "default": true },
        "taxaPercentual": { "type": "decimal", "default": 0, "description": "Taxa da operadora %" },
        "parcelasMax": { "type": "integer", "default": 1, "description": "Máximo de parcelas (para cartão)" },
        "instrucoes": { "type": "string", "description": "Instruções para o cliente" }
      },
      "examples": [
        { "nome": "Dinheiro", "tipo": "DINHEIRO", "taxaPercentual": 0 },
        { "nome": "PIX", "tipo": "PIX", "taxaPercentual": 0 },
        { "nome": "Cartão de Crédito", "tipo": "CARTAO_CREDITO", "taxaPercentual": 2.5, "parcelasMax": 12 },
        { "nome": "Cartão de Débito", "tipo": "CARTAO_DEBITO", "taxaPercentual": 1.5 },
        { "nome": "Boleto Bancário", "tipo": "BOLETO", "taxaPercentual": 0 }
      ]
    }
  },

