  "screens": {
    "dashboard": {
      "path": "/",
      "description": "Visão geral da academia",
      "components": [
        { "name": "StatsCards", "data": ["Total Alunos Ativos", "Prospects Novos", "Matrículas do Mês", "Receita do Mês"] },
        { "name": "ProspectsRecentes", "data": "Últimos 5 prospects" },
        { "name": "MatriculasVencendo", "data": "Matrículas que vencem em 7 dias" },
        { "name": "PagamentosPendentes", "data": "Pagamentos em atraso" }
      ]
    },
    "prospects": {
      "list": {
        "path": "/prospects",
        "description": "Lista de prospects com filtros",
        "features": ["Busca por nome/telefone", "Filtro por status", "Filtro por origem", "Ordenação"],
        "actions": ["Novo Prospect", "Editar", "Converter para Aluno", "Marcar como Perdido"]
      },
      "form": {
        "path": "/prospects/novo ou /prospects/:id",
        "description": "Formulário de cadastro/edição",
        "fields": ["nome*", "telefone*", "email", "cpf", "origem*", "observacoes"],
        "validation": "Verificar se telefone/cpf/email já existe"
      },
      "convert": {
        "path": "/prospects/:id/converter",
        "description": "Wizard de conversão prospect → aluno",
        "steps": [
          "1. Completar dados pessoais (CPF obrigatório, data nascimento, etc)",
          "2. Selecionar plano",
          "3. Definir forma de pagamento",
          "4. Confirmar e criar matrícula"
        ]
      }
    },
    "alunos": {
      "list": {
        "path": "/alunos",
        "description": "Lista de alunos",
        "features": ["Busca por nome/CPF", "Filtro por status", "Ver situação financeira"],
        "actions": ["Novo Aluno", "Editar", "Nova Matrícula", "Ver Histórico"]
      },
      "form": {
        "path": "/alunos/novo ou /alunos/:id",
        "description": "Formulário completo de aluno",
        "sections": [
          { "name": "Dados Pessoais", "fields": ["nome*", "cpf*", "rg", "dataNascimento*", "sexo*"] },
          { "name": "Contato", "fields": ["email*", "telefone*", "telefoneSec"] },
          { "name": "Endereço", "fields": ["cep", "logradouro", "numero", "complemento", "bairro", "cidade", "estado"] },
          { "name": "Emergência", "fields": ["contatoNome*", "contatoTelefone*", "parentesco"] },
          { "name": "Saúde", "fields": ["observacoesMedicas"] }
        ]
      },
      "detail": {
        "path": "/alunos/:id",
        "description": "Detalhes do aluno",
        "tabs": [
          { "name": "Dados", "content": "Informações pessoais" },
          { "name": "Matrículas", "content": "Histórico de matrículas" },
          { "name": "Financeiro", "content": "Pagamentos e débitos" }
        ]
      }
    },
    "planos": {
      "list": {
        "path": "/planos",
        "description": "Lista de planos disponíveis",
        "view": "Cards com destaque visual para plano recomendado",
        "actions": ["Novo Plano", "Editar", "Ativar/Desativar"]
      },
      "form": {
        "path": "/planos/novo ou /planos/:id",
        "fields": ["nome*", "tipo*", "duracaoDias*", "valor*", "valorMatricula", "atividades[]", "beneficios[]", "destaque"]
      }
    },
    "atividades": {
      "list": {
        "path": "/atividades",
        "description": "Lista de atividades/modalidades",
        "view": "Grid com ícones e cores"
      },
      "form": {
        "path": "/atividades/novo ou /atividades/:id",
        "fields": ["nome*", "categoria*", "descricao", "icone", "cor"]
      }
    },
    "contratos": {
      "list": {
        "path": "/contratos",
        "description": "Lista de contratos",
        "features": ["Filtro por status", "Filtro por período", "Ver vencendo"],
        "actions": ["Novo Contrato", "Renovar", "Cancelar"]
      },
      "form": {
        "path": "/contratos/nova",
        "description": "Wizard de novo contrato",
        "steps": [
          "1. Selecionar aluno (autocomplete)",
          "2. Selecionar plano",
          "3. Definir data início e calcular fim",
          "4. Aplicar desconto se houver",
          "5. Selecionar forma de pagamento",
          "6. Confirmar e gerar pagamento"
        ]
      }
    },
    "pagamentos": {
      "list": {
        "path": "/pagamentos",
        "description": "Lista de pagamentos",
        "features": ["Filtro por status", "Filtro por período", "Filtro por aluno"],
        "indicators": ["Verde=Pago", "Amarelo=Pendente", "Vermelho=Vencido"]
      },
      "receive": {
        "path": "/pagamentos/:id/receber",
        "description": "Modal de recebimento",
        "fields": ["dataPagamento", "formaPagamento", "observacoes"]
      }
    },
    "configuracoes": {
      "path": "/configuracoes",
      "tabs": [
        { "name": "Formas de Pagamento", "content": "CRUD de formas de pagamento" },
        { "name": "Academia", "content": "Dados da academia (tenant)" }
      ]
    }
  },

  "navigation": {
    "sidebar": [
      { "label": "Dashboard", "path": "/", "icon": "Home" },
      { "label": "Prospects", "path": "/prospects", "icon": "UserPlus", "badge": "count:novos" },
      { "label": "Alunos", "path": "/alunos", "icon": "Users" },
      { "label": "Contratos", "path": "/contratos", "icon": "ClipboardList" },
      { "label": "Planos", "path": "/planos", "icon": "CreditCard" },
      { "label": "Atividades", "path": "/atividades", "icon": "Activity" },
      { "label": "Pagamentos", "path": "/pagamentos", "icon": "DollarSign", "badge": "count:pendentes" },
      { "label": "Configurações", "path": "/configuracoes", "icon": "Settings" }
    ]
  },

  "tasks": [
    {
      "id": 1,
      "titulo": "Setup inicial do projeto",
      "descricao": "Criar projeto React com TypeScript, TailwindCSS, React Router. Configurar estrutura de pastas.",
      "prioridade": "ALTA",
      "dependencias": [],
      "entregaveis": [
        "Projeto inicializado com Vite + React + TypeScript",
        "TailwindCSS configurado",
        "React Router configurado",
        "Estrutura de pastas: /components, /pages, /hooks, /services, /types, /data",
        "Layout base com Sidebar"
      ]
