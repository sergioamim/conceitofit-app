  "businessFlows": {
    "prospectToAluno": {
      "description": "Fluxo completo de conversão de prospect para aluno",
      "steps": [
        "1. Criar Prospect: POST /api/v1/academia/prospects",
        "2. Atualizar status conforme evolução: PATCH /prospects/{id}/status",
        "3. Quando estiver pronto para converter:",
        "   POST /api/v1/academia/prospects/converter",
        "   - Enviar dados complementares (CPF, data nascimento, plano, etc)",
        "4. Sistema automaticamente:",
        "   - Cria registro Aluno",
        "   - Cria registro Matrícula (status: ATIVA)",
        "   - Cria registro Pagamento (status: PENDENTE)",
        "   - Atualiza Prospect (status: CONVERTIDO)"
      ]
    },
    "novaMatricula": {
      "description": "Criar matrícula para aluno existente",
      "steps": [
        "1. Verificar se aluno não tem matrícula ATIVA",
        "2. POST /api/v1/academia/matriculas com alunoId e planoId",
        "3. Sistema calcula dataFim automaticamente",
        "4. Sistema cria Pagamento automaticamente"
      ]
    },
    "renovacaoMatricula": {
      "description": "Renovar matrícula existente",
      "steps": [
        "1. POST /api/v1/academia/matriculas/{id}/renovar",
        "2. Opcional: passar planoId para trocar de plano",
        "3. Nova matrícula começa no dia seguinte ao fim da atual"
      ]
    },
    "recebimentoPagamento": {
      "description": "Registrar recebimento de pagamento",
      "steps": [
        "1. POST /api/v1/academia/pagamentos/{id}/receber",
        "2. Informar dataPagamento e formaPagamento",
        "3. Sistema atualiza status para PAGO",
        "4. Se aluno estava BLOQUEADO e não tem mais débitos, sistema desbloqueia automaticamente"
      ]
    },
    "inadimplencia": {
      "description": "Fluxo de inadimplência",
      "steps": [
        "1. Job verificarVencidos atualiza pagamentos vencidos",
        "2. Aluno com pagamento VENCIDO fica BLOQUEADO",
        "3. Ao pagar, aluno volta a ATIVO automaticamente"
      ]
    }
  },

