{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/app/**/page.tsx", "src/app/**/layout.tsx", "src/app/**/route.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/lib/mock/**",
    "src/**/*.test.{ts,tsx}",
    "src/**/*.spec.{ts,tsx}",
    "src/components/ui/**"
  ],
  "ignoreDependencies": [
    "@next/bundle-analyzer",
    "eslint-config-next",
    "shadcn",
    "tw-animate-css",
    "react-dom",
    "@types/react-dom",
    "tailwindcss",
    "postcss"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["playwright"]
}
