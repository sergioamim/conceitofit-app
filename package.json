{
  "name": "academia-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:mock": "next dev --webpack -p 3000 -H 127.0.0.1",
    "dev:api": "NEXT_PUBLIC_API_BASE_URL=http://localhost:8080 BACKEND_PROXY_TARGET=http://localhost:8080 next dev -p 3001 -H 0.0.0.0",
    "dev:api:scan": "NEXT_PUBLIC_REACT_SCAN=true NEXT_PUBLIC_API_BASE_URL=http://localhost:8080 BACKEND_PROXY_TARGET=http://localhost:8080 next dev -p 3001 -H 0.0.0.0",
    "dev:3001:api": "NEXT_PUBLIC_API_BASE_URL=http://localhost:8080 BACKEND_PROXY_TARGET=http://localhost:8080 next dev -p 3001 -H 0.0.0.0",
    "dev:3001:api:scan": "NEXT_PUBLIC_REACT_SCAN=true NEXT_PUBLIC_API_BASE_URL=http://localhost:8080 BACKEND_PROXY_TARGET=http://localhost:8080 next dev -p 3001 -H 0.0.0.0",
    "build": "next build",
    "build:preview": "next build",
    "start": "next start",
    "start:prod": "next start -p 3000 -H 0.0.0.0",
    "prod:local": "npm run build && npm run start:prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "audit:api": "node scripts/audit-api-clients.mjs",
    "coverage:clean": "node scripts/playwright-coverage.mjs clean",
    "coverage:unit": "node scripts/playwright-coverage.mjs unit",
    "coverage:smoke": "node scripts/playwright-coverage.mjs smoke",
    "coverage:report": "node scripts/playwright-coverage.mjs report --profile core",
    "coverage:report:full": "node scripts/playwright-coverage.mjs report --profile full",
    "coverage:baseline": "node scripts/playwright-coverage.mjs baseline --profile core",
    "coverage:baseline:full": "node scripts/playwright-coverage.mjs baseline --profile full",
    "coverage:gate": "node scripts/playwright-coverage.mjs gate --profile core",
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "dead-code": "knip --reporter compact"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.54.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.11.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-boundaries": "^6.0.1",
    "happy-dom": "^20.8.9",
    "knip": "^6.1.0",
    "postcss": "^8.5.8",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
